# Normalize text files to LF in the repo; Windows checkouts stay LF too to
# avoid CRLF creeping into Go/TS/SQL source.
* text=auto eol=lf

# Binary assets
*.png  binary
*.jpg  binary
*.jpeg binary
*.webp binary
*.ico  binary
*.svg  text

# Generated by tooling, should never round-trip through git diffs.
frontend/package-lock.json -diff
backend/go.sum            -diff
